{
  "info": {
    "name": "med-go API",
    "_postman_id": "4f450d2a-4c31-4d29-bbc8-c65b45000001",
    "description": "Assignment 1 Postman collection for doctor-service and appointment-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "doctorBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "appointmentBaseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "doctorId",
      "value": "replace-with-doctor-id"
    },
    {
      "key": "appointmentId",
      "value": "replace-with-appointment-id"
    }
  ],
  "item": [
    {
      "name": "Doctor Service",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{doctorBaseUrl}}/health",
              "host": [
                "{{doctorBaseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Dr. Aisha Seitkali\",\n  \"specialization\": \"Cardiology\",\n  \"email\": \"a.seitkali@clinic.kz\"\n}"
            },
            "url": {
              "raw": "{{doctorBaseUrl}}/doctors",
              "host": [
                "{{doctorBaseUrl}}"
              ],
              "path": [
                "doctors"
              ]
            }
          }
        },
        {
          "name": "List Doctors",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{doctorBaseUrl}}/doctors",
              "host": [
                "{{doctorBaseUrl}}"
              ],
              "path": [
                "doctors"
              ]
            }
          }
        },
        {
          "name": "Get Doctor By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{doctorBaseUrl}}/doctors/{{doctorId}}",
              "host": [
                "{{doctorBaseUrl}}"
              ],
              "path": [
                "doctors",
                "{{doctorId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Appointment Service",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{appointmentBaseUrl}}/health",
              "host": [
                "{{appointmentBaseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Initial cardiac consultation\",\n  \"description\": \"Patient referred for palpitations and shortness of breath\",\n  \"doctor_id\": \"{{doctorId}}\"\n}"
            },
            "url": {
              "raw": "{{appointmentBaseUrl}}/appointments",
              "host": [
                "{{appointmentBaseUrl}}"
              ],
              "path": [
                "appointments"
              ]
            }
          }
        },
        {
          "name": "List Appointments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{appointmentBaseUrl}}/appointments",
              "host": [
                "{{appointmentBaseUrl}}"
              ],
              "path": [
                "appointments"
              ]
            }
          }
        },
        {
          "name": "Get Appointment By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{appointmentBaseUrl}}/appointments/{{appointmentId}}",
              "host": [
                "{{appointmentBaseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}"
              ]
            }
          }
        },
        {
          "name": "Update Appointment Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{appointmentBaseUrl}}/appointments/{{appointmentId}}/status",
              "host": [
                "{{appointmentBaseUrl}}"
              ],
              "path": [
                "appointments",
                "{{appointmentId}}",
                "status"
              ]
            }
          }
        }
      ]
    }
  ]
}
