# Root combined binary configuration.
# For assignment defense, prefer the service-specific .env.example files inside each service directory.

DATABASE_URL=postgres://postgres:postgres@localhost:5433/med_go?sslmode=disable
DOCTOR_DATABASE_URL=postgres://postgres:postgres@localhost:5433/doctor_service?sslmode=disable
APPOINTMENT_DATABASE_URL=postgres://postgres:postgres@localhost:5433/appointment_service?sslmode=disable
NATS_URL=nats://localhost:4222

DOCTOR_SERVICE_ADDR=:8081
APPOINTMENT_SERVICE_ADDR=:8082
DOCTOR_SERVICE_GRPC_TARGET=127.0.0.1:8081
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60
RATE_LIMIT_RPM=100
GATEWAY_URL=http://localhost:8080
GATEWAY_PORT=8080
WORKER_POOL_SIZE=3
JOB_MAX_RETRIES=3
JOB_BACKOFF_SECONDS=1,2,4
